#!/bin/sh
set -e

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload || true
fi

if [ "$1" = "purge" ]; then
    rm -rf /etc/scraping-service
    rm -rf /var/log/scraping-service
    rm -rf /var/lib/scraping-service
    userdel scraping-service >/dev/null 2>&1 || true
fi

exit 0
